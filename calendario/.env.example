# ────────────────────────────────────────────────────────────────
# Supabase (admin auth + eventos do calendario)
# Crie o projeto em https://supabase.com e preencha estas chaves
# localmente em .env (NUNCA commite o .env real).
# ────────────────────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="eyJ...your-anon-key..."
SUPABASE_SERVICE_ROLE_KEY="eyJ...your-service-role-key..."

# ────────────────────────────────────────────────────────────────
# Sessao do admin (cookie httpOnly com JWT)
# Gere um valor aleatorio forte, ex.: openssl rand -hex 64
# ────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-openssl-rand-hex-64"

# ────────────────────────────────────────────────────────────────
# Token de bootstrap que libera a criacao do 1o admin
# Defina algo forte (e guarde um backup) e chame POST /api/auth/setup
# enviando o mesmo valor em X-Setup-Token. Apos criar o admin,
# este endpoint passa a recusar novas criacoes.
# ────────────────────────────────────────────────────────────────
SETUP_TOKEN="replace-with-strong-random-token"

# Porta do servidor Express (local dev apenas)
PORT=3001

# ────────────────────────────────────────────────────────────────
# DEPLOY NA VERCEL
# Nao existe .env na Vercel. Configure as variaveis em:
# https://vercel.com/dashboard → seu projeto → Settings → Environment Variables
# Adicione TODAS as variaveis acima (SUPABASE_URL, JWT_SECRET, etc.)
# ────────────────────────────────────────────────────────────────
