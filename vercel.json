{
  "buildCommand": "npm install && cd calendario && npm install && npm run build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/calendario/assets/(.*)",
      "dest": "/calendario/dist/assets/$1"
    },
    {
      "src": "/calendario(/.*)?",
      "dest": "/calendario/dist/index.html"
    }
  ]
}
